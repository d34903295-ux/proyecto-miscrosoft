    "video:render": "cd video && npx -y hyperframes render --output promo.mp4"
  },
  "dependencies": {
    "framer-motion": "^12.40.0",
    "lenis": "^1.3.23",
    "next": "^14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "tsx": "^4.22.4",
    "typescript": "5.5.3"
  }
}
