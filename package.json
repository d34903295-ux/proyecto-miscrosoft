{
  "name": "pre-mortem-institucional",
  "version": "1.0.0",
  "private": true,
  "description": "Agente de pre-mortem institucional: no predice, recuerda. Ancla cada riesgo a un caso real de la memoria de la empresa.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
